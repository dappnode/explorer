# =============================================================================
# DAppNode Explorer — environment variables
# Copy this file to `.env.development.local` (for dev) or
# `.env.production.local` (for build) and fill in real values.
#
# CRA inlines any variable prefixed with REACT_APP_ into the bundle at build
# time. Do NOT put real secrets here in a public deploy.
# =============================================================================

# GraphQL endpoint for the package registry subgraph
REACT_APP_SUBGRAPH_URI=https://gateway.thegraph.com/api/subgraphs/id/AnR9aNC4rEFzoCy44wcLHr3CmSpoCrKizPT8GMkKb8z5

# Bearer token for The Graph gateway. Required in production.
# Use the raw token value; a value prefixed with "Bearer " also works.
REACT_APP_GATEWAY_TOKEN=
